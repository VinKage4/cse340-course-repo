<%- include('partials/header') %>

<main>

    <h1><%= title %></h1>

    <form
        action="/register"
        method="POST"
    >

        <p>
            <label>Name</label>
            <input
                type="text"
                name="name"
                required
            >
        </p>

        <p>
            <label>Email</label>
            <input
                type="email"
                name="email"
                required
            >
        </p>

        <p>
            <label>Password</label>
            <input
                type="password"
                name="password"
                required
            >
        </p>

        <button type="submit">
            Register
        </button>

    </form>

</main>

<%- include('partials/footer') %>