<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <form action="/login" method="POST">
        <p>
            <label for="email">Email</label>
            <input
                type="email"
                id="email"
                name="email"
                required
            >
        </p>

        <p>
            <label for="password">Password</label>
            <input
                type="password"
                id="password"
                name="password"
                required
            >
        </p>

        <button type="submit">Login</button>
    </form>
</main>

<%- include('partials/footer') %>