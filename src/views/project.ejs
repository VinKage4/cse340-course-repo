<%- include('partials/header') %>

<main>
    <h1><%= project.title %></h1>

```
<p>
    <strong>Description:</strong>
    <%= project.description %>
</p>

<p>
    <strong>Date:</strong>
    <%= project.project_date %>
</p>

<p>
    <strong>Location:</strong>
    <%= project.location %>
</p>

<p>
    <strong>Organization:</strong>

    <a href="/organization/<%= project.organization_id %>">
        <%= project.organization_name %>
    </a>
</p>

<p>
    <a href="/assign-categories/<%= project.project_id %>">
        Edit Categories
    </a>
</p>

<% if (isLoggedIn) { %>

    <hr>

    <% if (isVolunteering) { %>

        <p>
            <strong>You are volunteering for this project.</strong>
        </p>

        <form
            action="/volunteer/<%= project.project_id %>/remove"
            method="POST">

            <button type="submit">
                Remove Me as Volunteer
            </button>

        </form>

    <% } else { %>

        <form
            action="/volunteer/<%= project.project_id %>"
            method="POST">

            <button type="submit">
                Volunteer for this Project
            </button>

        </form>

    <% } %>

<% } %>
```

</main>

<%- include('partials/footer') %>
